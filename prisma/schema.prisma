generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id         String   @id @default(cuid())
  name       String
  email      String?  @unique
  monthlyFee Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  payments        Payment[]
  monthlyStatuses ClientStatusByMonth[]
}

model Payment {
  id       String   @id @default(cuid())
  clientId String
  client   Client   @relation(fields: [clientId], references: [id])
  amount   Int
  paidAt   DateTime @default(now())

  // v3.12 soft-delete
  deletedAt    DateTime?
  deletedById  String?
  deleteReason String?

  @@index([clientId, amount, paidAt])
  @@index([clientId, deletedAt])
}

model BillingPeriod {
  id        String   @id @default(cuid())
  year      Int
  month     Int
  createdAt DateTime @default(now())

  // v3.12 locking
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedById String?

  clientStatuses ClientStatusByMonth[]

  @@unique([year, month])
}

model ClientStatusByMonth {
  id              String @id @default(cuid())
  clientId        String
  billingPeriodId String
  status          String @default("UNPAID")

  client        Client        @relation(fields: [clientId], references: [id])
  billingPeriod BillingPeriod @relation(fields: [billingPeriodId], references: [id])

  @@unique([clientId, billingPeriodId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  entityType String
  entityId   String
  action     String
  meta       Json?
  createdAt  DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ACCOUNTANT")
  createdAt DateTime @default(now())
}
